{
  "instanceName": "listmate-default",
  "network": {
    "host": "127.0.0.1"
  },
  "ports": {
    "frontend": 3000,
    "automation": 3001,
    "monitoring": 3010
  },
  "urls": {
    "frontend": "http://127.0.0.1:3000",
    "automation": "http://127.0.0.1:3001",
    "monitoring": "http://127.0.0.1:3010"
  },
  "timing": {
    "requestTimeoutMs": 4000,
    "statusIntervalMs": 5000,
    "startupDelayMs": 800
  },
  "services": {
    "frontend": {
      "cwd": ".",
      "devCommand": "npm run dev",
      "prodCommand": "npm run start",
      "env": {}
    },
    "automation": {
      "cwd": "automation-service",
      "command": "npm run start",
      "storageStatePath": "storageState.default.json",
      "ebayTokensPath": "ebay-tokens.default.json",
      "env": {}
    },
    "monitoring": {
      "cwd": "monitoring-service",
      "command": "npm run start",
      "jobStorePath": "data/removal-jobs.default.json",
      "env": {}
    }
  },
  "updates": {
    "enabled": false,
    "remote": "origin",
    "branch": "main",
    "repoCwd": ".",
    "stagingDir": ".update-staging",
    "checkIntervalMs": 60000,
    "applyStagedOnStart": false,
    "installCommand": "npm install",
    "automationInstallCommand": "npm install",
    "monitoringInstallCommand": "npm install",
    "buildCommand": "npm run build"
  }
}

