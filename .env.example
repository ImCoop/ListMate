# - automation-service/.env
# - automation-service/.env.local
# - the project root .env/.env.local
# Required for eBay API listing creation:
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_RUNAME=
# Optional:
# EBAY_MARKETPLACE_ID=EBAY_US
